rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write for standard collections during the event
    // In production, these should be locked to Cloud Functions or Auth.
    match /registrations/{document=**} {
      // Anyone can read registrations (needed for existing duplicate checks and admin dash)
      allow read: if true;
      
      // Allow creation ONLY if paymentStatus is Pending and amount is non-negative
      allow create: if request.resource.data.get('paymentStatus', '') == 'Pending' 
                    && request.resource.data.get('amount', 0) >= 0;
      
      // Allow updates ONLY IF:
      // 1. The amount is not changed.
      // 2. The paymentStatus is not changed OR if changed, it is not "Paid", "Verified", or "Refunded".
      allow update: if request.resource.data.get('amount', 0) == resource.data.get('amount', 0)
                    && (
                      (request.resource.data.get('paymentStatus', '') == resource.data.get('paymentStatus', '')) 
                      || (request.resource.data.get('paymentStatus', '') != 'Paid' 
                          && request.resource.data.get('paymentStatus', '') != 'Verified' 
                          && request.resource.data.get('paymentStatus', '') != 'Refunded')
                    );
                    
      // Only Admin SDK (Cloud Functions) can delete registrations now. Clients cannot delete.
      allow delete: if false; 
    }
    match /screenshots/{document=**} {
      allow read, write: if true;
    }
    match /sponsorships/{document=**} {
      allow read, write: if true;
    }
    match /expenditures/{document=**} {
      allow read, write: if true;
    }
    match /settings/{document=**} {
      allow read, write: if true;
    }
    match /site_logs/{document=**} {
      allow read, write: if true;
    }
    match /feedback/{document=**} {
      allow read, write: if true;
    }

    // 🛡️ SECURITY: Admin Audit Log is append-only
    // Nobody can delete or modify past audit logs from the client.
    match /admin_audit/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false; 
    }
  }
}
